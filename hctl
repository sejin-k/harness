#!/usr/bin/env python3
"""hctl — 하네스 컨트롤 CLI.

진행 상황/상태를 *스크립트로* 다루는 단일 진입점. (문서·프롬프트가 아님)

  hctl add <project> "<요구사항>" [--priority N]   요구사항 등록
  hctl run [--item WI-0001] [--loop] [--max N]      한 단계(또는 루프) 전진
  hctl status [--item WI-0001]                       상태 조회
  hctl log <WI-0001>                                 이벤트 타임라인
  hctl approve <WI-0001>                             NEEDS_HUMAN 승인·재개
  hctl projects                                      프로젝트 목록
  hctl reindex                                       index.json 복구
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))

from harness import config, state, state_machine  # noqa: E402


def cmd_add(args) -> int:
    # 위치 인자 정리: cwd/플러그인 모드에선 project를 생략하므로 한 개만 오면 requirement로 본다.
    project, requirement = args.project, args.requirement
    if requirement is None:
        project, requirement = None, project
    if requirement is None:
        print("[!] 요구사항이 필요하다.  예) hctl add \"<요구사항>\"  또는  hctl add <project> \"<요구사항>\"")
        return 1

    proj_dir = args.project_dir or os.environ.get("CLAUDE_PROJECT_DIR")
    # cwd/플러그인 모드: --project-dir/CLAUDE_PROJECT_DIR이 있거나, project 미지정·미등록일 때
    if proj_dir or project is None or project not in config.list_projects():
        d = Path(proj_dir or Path.cwd()).expanduser().resolve()
        # 첫 실행: harness.yaml이 없으면 기본 설정을 자동 생성(스캐폴드)
        cfg_path, created = config.scaffold_project_yaml(d)
        if created:
            detected = config.detect_commands(d).get("test", "")
            print(f"[+] harness.yaml 자동 생성: {cfg_path}")
            print(f"    추론된 test 명령: {detected or '(없음 — 직접 채워주세요)'}")
            print("    빌드/배포 명령은 비어 있을 수 있습니다. run 전에 검토·수정하세요.")
        # 깨진 설정이면 raw traceback 대신 친절 안내
        ok, msg = config.validate_project_yaml(cfg_path)
        if not ok:
            print(f"[!] harness.yaml 오류: {msg}")
            print("    파일을 수정하거나 `hctl init --force`로 새로 생성하세요.")
            return 1
        if msg:
            print(f"[주의] harness.yaml: {msg}")
        pcfg = config.load_project_at(d)
        item = state.create_work_item(pcfg["project"], requirement,
                                      args.priority, project_dir=str(d))
        print(f"[+] 등록됨: {item['id']}  project={item['project']}  dir={d}")
        print(f"    요구사항: {item['requirement']}")
        return 0

    # 레거시: projects/<name>/harness.yaml
    item = state.create_work_item(project, requirement, args.priority)
    print(f"[+] 등록됨: {item['id']}  project={item['project']}  state={item['state']}")
    print(f"    요구사항: {item['requirement']}")
    return 0


def _print_result(res: dict) -> None:
    action = res.get("action")
    icon = {"advanced": "✓", "retry": "↻", "needs_human": "✋",
            "error": "✗", "skip": "·", "noop": "·",
            "review_changes": "↩", "awaiting_approval": "✋"}.get(action, "?")
    line = f"  {icon} {res.get('item', '?')}  {action}  state={res.get('state')}"
    if res.get("phase"):
        line += f"  phase={res['phase']}"
    if res.get("commit"):
        line += f"  commit={res['commit']}"
    if res.get("cost_usd"):
        line += f"  ${res['cost_usd']:.4f}"
    if action == "review_changes" and res.get("round"):
        line += f"  (리뷰 라운드 {res['round']})"
    print(line)
    if res.get("detail"):
        print(f"       {res['detail']}")
    if res.get("reason"):
        print(f"       사유: {res['reason']}")


def cmd_run(args) -> int:
    if args.loop:
        workers = args.workers or int(config.load_global().get("workers", 2))
        print(f"[>] 동시 처리 루프 시작 (workers={workers}, max={args.max}) ...")
        summary = state_machine.run_loop(workers=workers, max_steps=args.max,
                                         on_result=_print_result)
        print(f"[=] 루프 종료 — {summary['steps']}개 단계 전진 처리.")
        return 0

    item_id = args.item or state_machine.pick_next()
    if not item_id:
        print("[=] 처리할 작업 없음.")
        return 0
    if not state.item_exists(item_id):
        print(f"[!] 없는 작업 항목: {item_id}")
        return 1
    print(f"[>] {item_id} 전진 중 ...")
    _print_result(state_machine.advance(item_id))
    return 0


def cmd_status(args) -> int:
    if args.item:
        if not state.item_exists(args.item):
            print(f"[!] 없는 작업 항목: {args.item}")
            return 1
        item = state.load_item(args.item)
        print(f"  {item['id']}  [{item['state']}]  project={item['project']}  branch={item['branch']}")
        print(f"  요구사항: {item['requirement']}")
        print(f"  시도: {item['attempts']}")
        if item.get("pending_phase"):
            print(f"  ✋ 승인 대기: {item['pending_phase']}  (hctl approve {item['id']})")
        if item.get("approvals"):
            print(f"  승인됨: {list(item['approvals'].keys())}")
        if item.get("last_error"):
            print(f"  마지막 오류: {item['last_error']}")
        for ph, art in (item.get("artifacts") or {}).items():
            print(f"  - {ph}: commit={art.get('commit')}  ${art.get('cost_usd', 0):.4f}  ({art.get('gate_detail')})")
        return 0

    idx = state.load_index()
    items = idx["items"]
    if not items:
        print("(작업 항목 없음)")
        return 0
    print(f"{'ID':<9} {'STATE':<12} {'PROJ':<16} REQUIREMENT")
    print("-" * 70)
    for it in items:
        print(f"{it['id']:<9} {it['state']:<12} {it['project'][:15]:<16} {it['requirement']}")
    print(f"\n총 {idx['count']}건  (index {idx['generated_at']})")
    return 0


def cmd_log(args) -> int:
    if not state.item_exists(args.item):
        print(f"[!] 없는 작업 항목: {args.item}")
        return 1
    for ev in state.read_events(args.item):
        data = ev.get("data", {})
        extra = ""
        if "phase" in data:
            extra += f" phase={data['phase']}"
        if "passed" in data:
            extra += f" passed={data['passed']}"
        if "detail" in data:
            extra += f" — {data['detail']}"
        if "reason" in data:
            extra += f" — {data['reason']}"
        print(f"{ev['ts']}  {ev['kind']:<14}{extra}")
    return 0


def cmd_approve(args) -> int:
    if not state.item_exists(args.item):
        print(f"[!] 없는 작업 항목: {args.item}")
        return 1
    res = state_machine.approve(args.item)
    print(f"[✓] {res['action']}  {args.item}  → state={res.get('state')}")
    if res.get("reason"):
        print(f"    {res['reason']}")
    return 0


def _dryrun(cmd: str, cwd: Path, timeout: int = 60) -> int:
    """명령을 한 번 실행해 종료코드만 반환 (init 검증용)."""
    import subprocess
    try:
        p = subprocess.run(cmd, cwd=str(cwd), shell=True, capture_output=True,
                           timeout=timeout)
        return p.returncode
    except subprocess.TimeoutExpired:
        return 124
    except Exception:
        return 127


def cmd_init(args) -> int:
    proj_dir = args.project_dir or os.environ.get("CLAUDE_PROJECT_DIR") or str(Path.cwd())
    d = Path(proj_dir).expanduser().resolve()
    cfg_path, created = config.scaffold_project_yaml(d, overwrite=args.force)
    if not created:
        print(f"[·] 이미 존재: {cfg_path}  (덮어쓰려면 --force)")
        ok, msg = config.validate_project_yaml(cfg_path)
        if not ok:
            print(f"    [!] 설정 오류: {msg}  — 고치거나 --force로 재생성")
            return 1
        if msg:
            print(f"    [주의] {msg}")
        return 0

    cmds = config.detect_commands(d)
    print(f"[+] harness.yaml 생성: {cfg_path}")
    print(f"    추론: test='{cmds['test']}'  build='{cmds['build']}'  lint='{cmds['lint']}'")

    # ④ git 전제조건 (하네스는 worktree 격리에 git이 필요)
    g = config.git_status(d)
    if not g["is_repo"]:
        print("    [!] git 레포가 아님 — 하네스는 git이 필요하다.")
        print(f"        예) git -C \"{d}\" init -b main && git -C \"{d}\" commit --allow-empty -m init")
    elif not g["has_commit"]:
        print("    [!] 커밋이 없음 — 트렁크 기준점이 될 최소 1개 커밋이 필요하다.")

    # ③ test 드라이런 (잘못된 추론·환경 문제 조기 발견)
    if not args.no_check and cmds["test"]:
        rc = _dryrun(cmds["test"], d)
        print(f"    [>] test 드라이런: {cmds['test']}  → rc={rc}"
              + ("  (통과)" if rc == 0 else "  (실패 — 명령/환경 확인)"))

    print("    build/deploy/health_check 등은 비어 있을 수 있다 — 검토 후 커밋하세요.")
    return 0


def cmd_projects(args) -> int:
    projs = config.list_projects()
    if not projs:
        print("(등록된 프로젝트 없음 — projects/<name>/harness.yaml 필요)")
        return 0
    for p in projs:
        cfg = config.load_project(p)
        print(f"  {p:<20} repo={cfg['repo']}  test='{cfg['commands'].get('test', '')}'")
    return 0


def cmd_reindex(args) -> int:
    idx = state.reindex()
    print(f"[✓] index.json 재생성: {idx['count']}건")
    return 0


def cmd_worktrees(args) -> int:
    from harness import worktree
    projs = [args.project] if args.project else config.list_projects()
    for p in projs:
        cfg = config.load_project(p)
        print(f"[{p}]  (concurrency={cfg.get('concurrency', 1)})")
        print(worktree.list_worktrees(Path(cfg["repo"])).rstrip())
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="hctl", description="개발 하네스 컨트롤 CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    a = sub.add_parser("add", help="요구사항 등록")
    a.add_argument("project", nargs="?",
                   help="레거시 등록명(projects/<name>). cwd/플러그인 모드에선 생략")
    a.add_argument("requirement", nargs="?")
    a.add_argument("--project-dir", dest="project_dir",
                   help="프로젝트 디렉토리(플러그인/cwd 모드). 기본: $CLAUDE_PROJECT_DIR 또는 현재 위치")
    a.add_argument("--priority", type=int, default=100)
    a.set_defaults(func=cmd_add)

    r = sub.add_parser("run", help="한 단계(또는 루프) 전진")
    r.add_argument("--item", help="특정 작업 항목 (생략 시 큐에서 자동 선택)")
    r.add_argument("--loop", action="store_true", help="처리할 작업이 없을 때까지 반복")
    r.add_argument("--max", type=int, default=50, help="루프 최대 스텝")
    r.add_argument("--workers", type=int, default=None,
                   help="동시 처리 워커 수 (기본: config.yaml workers)")
    r.set_defaults(func=cmd_run)

    s = sub.add_parser("status", help="상태 조회")
    s.add_argument("--item", help="특정 작업 항목 상세")
    s.set_defaults(func=cmd_status)

    lg = sub.add_parser("log", help="이벤트 타임라인")
    lg.add_argument("item")
    lg.set_defaults(func=cmd_log)

    ap = sub.add_parser("approve", help="NEEDS_HUMAN 승인·재개")
    ap.add_argument("item")
    ap.set_defaults(func=cmd_approve)

    it = sub.add_parser("init", help="프로젝트에 harness.yaml 생성 (스캐폴드)")
    it.add_argument("--project-dir", dest="project_dir",
                    help="프로젝트 디렉토리 (기본: $CLAUDE_PROJECT_DIR 또는 현재 위치)")
    it.add_argument("--force", action="store_true", help="기존 harness.yaml 덮어쓰기 (.bak 백업)")
    it.add_argument("--no-check", action="store_true", help="test 드라이런 생략")
    it.set_defaults(func=cmd_init)

    sub.add_parser("projects", help="프로젝트 목록").set_defaults(func=cmd_projects)
    sub.add_parser("reindex", help="index.json 복구").set_defaults(func=cmd_reindex)

    wt = sub.add_parser("worktrees", help="git worktree 목록 (동시 처리 격리)")
    wt.add_argument("project", nargs="?", help="특정 프로젝트 (생략 시 전체)")
    wt.set_defaults(func=cmd_worktrees)
    return p


def main() -> int:
    args = build_parser().parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
