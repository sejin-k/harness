#!/usr/bin/env python3
"""dev-harness 플러그인 런처.

동봉 엔진(`${CLAUDE_PLUGIN_ROOT}/engine`)으로 `hctl`을 실행한다.
- 상태·worktree : `${CLAUDE_PLUGIN_DATA}` (사용자 홈, 프로젝트 바깥)
- 대상 프로젝트  : `${CLAUDE_PROJECT_DIR}` 또는 현재 위치 (설정 harness.yaml은 여기서 읽음)

엔진 위치는 `HARNESS_ENGINE` env로 덮어쓸 수 있다(개발용). 기본은 플러그인에 동봉된 `engine/`.
"""
from __future__ import annotations

import os
import runpy
import sys
from pathlib import Path

PLUGIN_ROOT = Path(__file__).resolve().parents[1]
engine = Path(os.environ.get("HARNESS_ENGINE") or (PLUGIN_ROOT / "engine")).resolve()

if not (engine / "hctl").exists():
    sys.stderr.write(f"[dev-harness] 엔진을 찾을 수 없음: {engine}\n")
    sys.exit(2)

sys.path.insert(0, str(engine))   # `harness` 패키지 import 가능하게
sys.argv[0] = "hctl"
runpy.run_path(str(engine / "hctl"), run_name="__main__")
